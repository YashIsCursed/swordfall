; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Swordfall"
config/description="A 3D Action RPG game with multiplayer support"
run/main_scene="res://Scenes/UI/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameData="*res://Global/Scripts/GameData.gd"
SceneManager="*res://Global/Scripts/SceneManager.gd"
MultiplayerManager="*res://Global/Classes/MultiplayerManager/MultiplayerManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://Global/": "orange",
"res://Global/Classes/": "green",
"res://Global/Classes/Entity/": "teal",
"res://Global/Classes/Entity/Player/": "purple",
"res://Global/Classes/MultiplayerManager/": "blue",
"res://Global/Classes/World/": "pink",
"res://Global/Scripts/": "red",
"res://Levels/": "yellow",
"res://Scenes/": "gray",
"res://Scenes/UI/": "blue"
}

